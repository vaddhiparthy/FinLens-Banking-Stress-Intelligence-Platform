surya.vaddhiparthy.com {

	log {
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 8
			roll_keep_for 720h
		}
		format json
	}
	import security_headers
	redir /privacy-preserving-authentication-audit-data-platform /privacy-preserving-authentication-audit-data-platform/ 308

	handle_path /privacy-preserving-authentication-audit-data-platform* {
		reverse_proxy pramanaledger-demo:8075
	}

	redir /finlens /finlens/ 308

	handle /finlens* {
		reverse_proxy finlens-streamlit-public:8501
	}

	# vCAS demo (served by separate container; prefix stripped by handle_path)
	handle_path /vcas-demo* {
		reverse_proxy vcas-demo:8000
	}

	handle {
		reverse_proxy surya-unified-site:8088
	}
}

