# Copy this file to `.env`, fill in the active connector values, then run:
# powershell -ExecutionPolicy Bypass -File .\scripts\start_finlens.ps1

# Core runtime
FINLENS_ENVIRONMENT=local
FINLENS_DATA_MODE=mock
FINLENS_ARTIFACT_DIR=data
FINLENS_ACTIVE_SOURCES=fdic,fred,qbp,nic
ROOT_DOMAIN=vaddhiparthy.com
PROJECT_DOMAIN=surya.vaddhiparthy.com
FINLENS_PUBLIC_BASE_URL=https://surya.vaddhiparthy.com/finlens
FINLENS_API_BASE_URL=
FINLENS_TELEMETRY_ENABLED=true
STREAMLIT_APP_TITLE=FinLens Dashboard

# Stable approved sources
FDIC_FAILED_BANKS_URL=https://www.fdic.gov/bank-failures/download-data.csv
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org/fred
FRED_SERIES_IDS=UNRATE,DGS10,DGS2,BAA10Y,NFCI,CPIAUCSL
# Normalized CSV/JSON contract for Stress Pulse:
# quarter,net_income,roa,nim,problem_banks,asset_yield,funding_cost,noncurrent_rate,nco_rate,afs_losses,htm_losses
FDIC_QBP_SOURCE_URL=
# Current parent-only NIC CSV/JSON artifact
NIC_CURRENT_PARENT_SOURCE_URL=

# Deferred / dormant scaffolding kept in repo but not part of the current startup path
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_S3_MIRROR_ENABLED=false
AWS_S3_RAW_BUCKET=finlens-raw
AWS_S3_DLQ_BUCKET=finlens-dlq
AWS_S3_MARTS_BUCKET=finlens-marts
AWS_S3_DOCS_BUCKET=finlens-docs
AWS_S3_TFSTATE_BUCKET=finlens-tfstate
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=FINLENS_ROLE
SNOWFLAKE_LOADING_WAREHOUSE=LOADING_WH
SNOWFLAKE_TRANSFORMING_WAREHOUSE=TRANSFORMING_WH
SNOWFLAKE_DATABASE_RAW=FINLENS_RAW
SNOWFLAKE_DATABASE_STAGING=FINLENS_STAGING
SNOWFLAKE_DATABASE_INTERMEDIATE=FINLENS_INTERMEDIATE
SNOWFLAKE_DATABASE_MARTS=FINLENS_MARTS
CLOUDFLARE_API_TOKEN=
FASTAPI_ENV=local
POSTGRES_SYNC_DSN=
POSTGRES_SYNC_SCHEMA=finlens
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
