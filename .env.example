# FinLens environment template. Copy to .env and fill in. .env is gitignored; never commit secrets.
# Storage is the VPS local filesystem (data/raw) — there are no cloud object-store credentials.

# Runtime
FINLENS_ENVIRONMENT=local
FINLENS_DATA_MODE=live
FINLENS_ACTIVE_SOURCES=fdic,fred,qbp,nic
ROOT_DOMAIN=example.com
PROJECT_DOMAIN=finlens.example.com
FINLENS_PUBLIC_BASE_URL=
FINLENS_API_BASE_URL=

# Sources
FDIC_FAILED_BANKS_URL=https://www.fdic.gov/bank-failures/download-data.csv
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org/fred
FRED_SERIES_IDS=UNRATE,DGS10,DGS2,BAA10Y,NFCI,CPIAUCSL

# Assistant (RAG synthesis via OpenRouter). Key is read from the environment only.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Edge / control plane
CLOUDFLARE_API_TOKEN=
POSTGRES_SYNC_DSN=
POSTGRES_SYNC_SCHEMA=finlens
TELEGRAM_BOT_TOKEN=

# Snowflake — OPTIONAL, credential-gated warehouse target (DuckDB is the warehouse of record)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=FINLENS_ROLE
SNOWFLAKE_DATABASE_RAW=FINLENS_RAW
SNOWFLAKE_DATABASE_STAGING=FINLENS_STAGING
SNOWFLAKE_DATABASE_INTERMEDIATE=FINLENS_INTERMEDIATE
SNOWFLAKE_DATABASE_MARTS=FINLENS_MARTS
